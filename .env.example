# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Leonardo.ai for avatar generation (optional)
LEONARDO_API_KEY=your-leonardo-api-key

# OpenAI for profile embeddings (optional - recommendations disabled if missing)
OPENAI_API_KEY=your-openai-api-key

# Admin dashboard access (required)
ADMIN_API_KEY=generate-a-uuid-here
